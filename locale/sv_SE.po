#. TRANSLATORS: Error shown during registration when the username/email is already taken.
msgid "User already exists."
msgstr "Användaren finns redan."

#. TRANSLATORS: Error shown when a user was created but automatic login failed.
msgid "User created but could not login."
msgstr "Användaren skapades men inloggningen misslyckades."

#. TRANSLATORS: Exception message when a user cannot be found for provided identifier.
msgid "User not found."
msgstr "Användaren hittades inte."

#. TRANSLATORS: Error when a user lookup by username/email fails; %s is replaced by the username.
#, php-format
msgid "User with username %s does not exist."
msgstr "Användaren med användarnamnet %s finns inte."

#, php-format
msgid "Username %s is already taken"
msgstr "Användarnamnet %s är redan upptaget"

#. TRANSLATORS: Error when username or password is missing from login request.
#. TRANSLATORS: Error when registration omits username or password.
msgid "Username and password are required."
msgstr "Användarnamn och lösenord krävs."

#. TRANSLATORS: Error when username is missing from recovery request.
msgid "Username is required."
msgstr "Användarnamn krävs."

#. TRANSLATORS: Validation error shown when provided username is not a valid e-mail address.
msgid "Username must be a valid e-mail."
msgstr "Användarnamnet måste vara en giltig e-postadress."

#. TRANSLATORS: Validation error when username is not a valid email address.
#. TRANSLATORS: Validation error when registration username is not a valid email address.
msgid "Username must be a valid email address."
msgstr "Användarnamnet måste vara en giltig e-postadress."

